{
  "components": [
    {
      "key": "html",
      "type": "htmlelement",
      "input": false,
      "label": "HTML",
      "content": "Fields below are related to Xential document generation",
      "refreshOnChange": false
    },
    {
      "key": "caseDefinitionName",
      "type": "hidden",
      "input": true,
      "label": "Document definition name",
      "attributes": {
        "data-testid": "xential-genereren.kies-sjabloon-caseDefinitionName"
      },
      "properties": {
        "sourceKey": "case:documentDefinitionId.name",
        "targetKey": "pv:caseType"
      }
    },
    {
      "key": "caseDefinitionVersionTag",
      "type": "hidden",
      "input": true,
      "label": "Case definition version tag",
      "attributes": {
        "data-testid": "xential-genereren.kies-sjabloon-caseDefinitionVersionTag"
      },
      "properties": {
        "sourceKey": "case:definitionId.versionTag",
        "targetKey": "pv:caseTypeVersion"
      }
    },
    {
      "key": "tempcontent",
      "data": {
        "url": "../api/management/v1/template?caseDefinitionKey={{ data.caseDefinitionName }}&caseDefinitionVersionTag={{ data.caseDefinitionVersionTag }}&templateType=text&page=0&size=10000",
        "method": "GET",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{localStorage.getItem('formioToken')}}"
          }
        ]
      },
      "type": "select",
      "input": true,
      "label": "Template",
      "widget": "choicesjs",
      "dataSrc": "url",
      "lazyLoad": false,
      "template": "<span>{{ item.key }}</span>",
      "validate": {
        "required": true
      },
      "refreshOn": "document",
      "attributes": {
        "data-testid": "xential-genereren.kies-sjabloon-tempcontent"
      },
      "persistent": "client-only",
      "selectValues": "content",
      "valueProperty": "key",
      "clearOnRefresh": true
    },
    {
      "key": "pv:xentialData",
      "type": "hidden",
      "input": true,
      "label": "Set template",
      "attributes": {
        "data-testid": "xential-genereren.kies-sjabloon-pv-xentialData"
      },
      "defaultValue": false,
      "calculateValue": "value = 'template:' + data.tempcontent"
    },
    {
      "key": "submit",
      "type": "button",
      "input": true,
      "label": "Afronden",
      "showValidations": false,
      "disableOnInvalid": true
    }
  ]
}
